<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.vaultassistant.processor</string>
	<key>ProgramArguments</key>
	<array>
		<string>/usr/bin/env</string>
		<string>uv</string>
		<string>run</string>
		<string>processor.py</string>
	</array>
	<key>WorkingDirectory</key>
	<string>/Volumes/1TB/Repos/vault-assistant</string>
	<key>StartInterval</key>
	<integer>1800</integer>
	<key>StandardOutPath</key>
	<string>~/.vault-assistant/logs/processor-stdout.log</string>
	<key>StandardErrorPath</key>
	<string>~/.vault-assistant/logs/processor-stderr.log</string>
	<key>EnvironmentVariables</key>
	<dict>
		<key>PATH</key>
		<string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
	</dict>
</dict>
</plist>
