# ============================================================================
# VAULT ASSISTANT CONFIGURATION
# ============================================================================
#
# IMPORTANT: You only NEED to change VAULT_PATH below.
# Everything else has sensible defaults for typical users.
#
# For detailed setup: https://github.com/alexkibler/vault-assistant/blob/main/docs/INSTALLATION.md
# For quick start: https://github.com/alexkibler/vault-assistant/blob/main/QUICKSTART.md
#

# ============================================================================
# REQUIRED: Your Obsidian Vault Location
# ============================================================================
#
# This is the ONLY setting you must change.
#
# macOS (iCloud sync):
#   ~/Library/Mobile Documents/iCloud~md~obsidian/Documents/MyVault
# macOS (local):
#   ~/Documents/MyVault
# Linux:
#   ~/vault
#   /mnt/c/Users/Username/Documents/ObsidianVault (WSL2)
# Windows (WSL2):
#   /mnt/c/Users/Username/Documents/ObsidianVault
#
# Use literal paths with spaces (no symlinks):
VAULT_PATH=~/Library/Mobile Documents/iCloud~md~obsidian/Documents/iCloud

# ============================================================================
# OPTIONAL: Vector Database & Indexing
# ============================================================================
#
# LanceDB index location (auto-created, outside vault)
# Default: ~/.vault-assistant/lancedb (fine for most users)
LANCEDB_PATH=~/.vault-assistant/lancedb

# ============================================================================
# OPTIONAL: Ollama Configuration
# ============================================================================
#
# These work with default Ollama setup. Only change if:
# 1. Ollama runs on different host/port
# 2. You have custom models installed
#
# Ollama Base URL (where Ollama is running)
# Default: http://localhost:11434 ✓
# Remote: http://192.168.1.100:11434
OLLAMA_BASE_URL=http://localhost:11434

# Embedding model (for semantic search)
# Recommended: nomic-embed-text (perfect for RAG)
# Alternatives: all-minilm-l6-v2, bge-small-en-v1.5
# Pull models with: ollama pull nomic-embed-text
OLLAMA_EMBED_MODEL=nomic-embed-text

# Chat model (for generating answers)
# Recommended: llama3.1:8b (balanced speed/quality)
# Alternatives: llama2, neural-chat, mistral
# Pull models with: ollama pull llama3.1:8b
OLLAMA_CHAT_MODEL=llama3.1:8b

# ============================================================================
# OPTIONAL: Audio Transcription (Whisper)
# ============================================================================
#
# Only needed for voice input (Siri Shortcuts, etc)
# Default settings work on Apple Silicon Macs
#
# macOS (Apple Silicon): mlx-community/whisper-base (fastest) ✓
# Linux/Windows: base (uses faster-whisper, slower but works)
# Larger models: small, medium, large (more accurate, slower)
WHISPER_MODEL=mlx-community/whisper-base

# Language of your voice input
WHISPER_LANGUAGE=en

# ============================================================================
# OPTIONAL: API Server
# ============================================================================
#
# HOST: What interface to listen on
#   0.0.0.0 = accessible from network (for Siri, etc) ✓
#   127.0.0.1 = localhost only
# PORT: HTTP port (change if 8765 is already in use)
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8765

# ============================================================================
# NOTES
# ============================================================================
#
# 1. Required models must be installed:
#    ollama pull nomic-embed-text
#    ollama pull llama3.1:8b
#
# 2. Ollama must be running:
#    ollama serve  (in another terminal)
#
# 3. Verify setup:
#    uv run uvicorn main:app --host 0.0.0.0 --port 8765
#    curl http://localhost:8765/health
#
# 4. For issues, see:
#    - QUICKSTART.md for quick setup
#    - docs/INSTALLATION.md for detailed setup
#    - GitHub issues for bugs
