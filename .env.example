# Vault — use the literal iCloud Drive path, not a symlink
VAULT_PATH=~/Library/Mobile Documents/iCloud~md~obsidian/Documents/MyVault

# LanceDB index location (outside the vault so it doesn't get indexed)
LANCEDB_PATH=~/.vault-assistant/lancedb

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.2

# Whisper
WHISPER_MODEL=mlx-community/whisper-large-v3-turbo
WHISPER_LANGUAGE=en

# Vault write targets
DAILY_NOTE_FORMAT=%Y-%m-%d
INBOX_FILE=inbox.md

# Service
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8765
